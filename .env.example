# County AI Assurance Operations Center runtime configuration

# Backend
DATABASE_URL=postgresql+psycopg://air_platform:air_platform@postgres:5432/air_platform
API_HOST=0.0.0.0
API_PORT=8000
API_HOST_PORT=8000
API_RELOAD=true
ENVIRONMENT=development
RUN_SEED=true
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SCANNER_STORAGE_ROOT=/data/scanner-runs

# Frontend
FRONTEND_HOST_PORT=3000
NEXT_PUBLIC_API_URL=/api/backend
NEXT_INTERNAL_API_URL=http://backend:8000
WATCHPACK_POLLING=true

# PostgreSQL
POSTGRES_DB=air_platform
POSTGRES_USER=air_platform
POSTGRES_PASSWORD=air_platform
POSTGRES_PORT=5432
